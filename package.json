{
  "name": "claude-overview",
  "version": "0.1.0",
  "description": "Multi-session Claude Code dashboard TUI",
  "type": "module",
  "bin": {
    "claude-overview": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "npm install && npm run build && npm link"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^6.0.0",
    "meow": "^13.0.0",
    "react": "^19.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
